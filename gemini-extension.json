{
  "name": "gemini-code-intel",
  "version": "0.1.3",
  "description": "Semantic code search and indexing for Gemini CLI",
  "mcpServers": {
    "gemini-code-intel": {
      "command": "node",
      "args": [
        "./packages/mcp/dist/index.js"
      ],
      "env": {
        "DB_URI": "~/.gemini-code-intel/db"
      }
    }
  }
}
